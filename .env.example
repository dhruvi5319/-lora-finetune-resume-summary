# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored — your real tokens never get committed.

# Hugging Face access token (https://huggingface.co/settings/tokens)
# Needs at least "read" to download Llama, "write" to push your model later.
HF_TOKEN=

# Teacher model for generating ideal summaries during dataset building (Phase 1).
# Reuses the same OpenAI key your screener already uses, OR an Anthropic key.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
